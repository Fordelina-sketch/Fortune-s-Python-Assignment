def validate_credentials(username, password):
    results = {}
    
    # check username rules
    if len(username) < 6:
        results["username_length"] = "Username must be at least 6 characters."
    if " " in username:
        results["username_space"] = "Username cannot have spaces."
    if not username[0].isalpha():
        results["username_start"] = "Username must start with a letter."
        
    # check password rules manually with loops
    has_upper = False
    has_lower = False
    has_digit = False
    has_special = False
    special_chars = "!@#$%^&*()-_+="
    
    for char in password:
        if char.isupper():
            has_upper = True
        elif char.islower():
            has_lower = True
        elif char.isdigit():
            has_digit = True
        elif char in special_chars:
            has_special = True
            
    # record password errors
    if len(password) < 8:
        results["pass_length"] = "Password must be at least 8 characters."
    if not has_upper:
        results["pass_upper"] = "Password needs an uppercase letter."
    if not has_lower:
        results["pass_lower"] = "Password needs a lowercase letter."
    if not has_digit:
        results["pass_digit"] = "Password needs a number."
    if not has_special:
        results["pass_special"] = "Password needs a special character."
        
    if len(results) == 0:
        results["success"] = "All good! Credentials are valid."
        
    return results

def generate_suggestions(password):
    tips = []
    if len(password) < 8:
        tips.append("Tip: Make your password longer.")
    if password.isalpha():
        tips.append("Tip: Add some numbers and symbols to make it stronger.")
    if password.islower():
        tips.append("Tip: Mix capital and lowercase letters.")
    return tips

# Test with 6 combinations
tests = [
    ("admin", "pass"), # too short, missing everything
    ("john doe", "password123!"), # space in username
    ("1user", "Valid123!"), # username starts with number
    ("maryjane", "nouppercase1!"), # password missing upper
    ("peterparker", "NoSpecialChar123"), # password missing special
    ("validUser", "PerfectPass123!") # valid
]

for user, pwd in tests:
    print(f"\nTesting Username: '{user}', Password: '{pwd}'")
    errors = validate_credentials(user, pwd)
    for key, msg in errors.items():
        print("-", msg)
        
    tips = generate_suggestions(pwd)
    for tip in tips:
        print(tip)